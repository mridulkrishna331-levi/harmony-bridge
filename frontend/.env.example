# ─────────────────────────────────────────────────────
#  HarmonyBridge Frontend — Environment Variable Template
#  Add these keys in: Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────

# Your deployed backend URL (e.g. Railway, Render, or custom domain — NO trailing slash)
VITE_API_BASE_URL=https://your-backend-domain.com

# Socket.io server URL (usually same as API server)
VITE_SOCKET_URL=https://your-backend-domain.com
