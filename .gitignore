# ───────────────────────────────────────────────
#  HarmonyBridge — .gitignore
# ───────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.output/

# Vite cache
.vite/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/

# Misc
*.tsbuildinfo
